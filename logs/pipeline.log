[SQL: DELETE FROM trial.air_pollution_grid_mapping;

INSERT INTO trial.air_pollution_grid_mapping (way_id, grid_uid, grid_id, intersection_length_m)
SELECT
    w.id AS way_id,
    lpg.uid AS grid_uid,
    lpg.grid_id,
    ST_Length(
        ST_Intersection(
            w.geom_25833,
            ST_Expand(lpg.geom_25833, 25)
        )
    ) AS intersection_length_m
FROM (
    SELECT
        id,
        COALESCE(geometry_25833, ST_Transform(geometry, 25833)) AS geom_25833
    FROM (SELECT * FROM trial.ways_base LIMIT 10000 OFFSET 0) WHERE geometry_25833 IS NOT NULL OR geometry IS NOT NULL
) w
JOIN LATERAL (
    SELECT DISTINCT ON (e.grid_id)
        e.uid,
        e.grid_id,
        e.geom_25833
    FROM trial.air_pollution_grid_enrichment e
    WHERE e.geom_25833 IS NOT NULL
      AND ST_DWithin(w.geom_25833, e.geom_25833, 36)
    ORDER BY e.grid_id, e.forecast_time DESC NULLS LAST, e.uid DESC
) lpg ON ST_Intersects(w.geom_25833, ST_Expand(lpg.geom_25833, 25))
WHERE ST_Length(ST_Intersection(w.geom_25833, ST_Expand(lpg.geom_25833, 25))) > 0;
]
