# Copy to `.env` and fill in real values. `.env` is gitignored.
# Loaded automatically by run.py via python-dotenv.
# Values set here override the matching fields in config.yaml (see main_core/core_config.py::_apply_env_overrides).

# --- Database (consumed by CoreConfig / SQLAlchemy) ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=test_db
DB_USER=postgres
DB_PASSWORD=

# --- Postgres CLI tools (osm2pgsql, osm2pgrouting, psql) ---
# Mirror DB_PASSWORD here so subprocess calls pick it up.
PGPASSWORD=
